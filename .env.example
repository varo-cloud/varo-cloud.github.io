# =============================================================================
# Varo.cloud Frontend — Environment Variables
# =============================================================================
#
# Copy this file to create your local / deployment config:
#
#   cp .env.example .env.development   # local dev (npm run dev)
#   cp .env.example .env.staging       # staging build (npm run build:staging)
#   cp .env.example .env.production    # production build (npm run build)
#
# Real .env.* files are gitignored. Only this template is committed.
# All variables must be prefixed with VITE_ to be exposed to the client bundle.
#
# =============================================================================

# -----------------------------------------------------------------------------
# API & Mock
# -----------------------------------------------------------------------------

# Enable vite-plugin-mock during `npm run dev`.
# Set to true for fully offline development; false to hit a real backend via proxy
# or absolute VITE_API_BASE_URL.
VITE_USE_MOCK=true

# Base path for API requests (resolved with VITE_BASE).
# Local dev with proxy: /api  →  proxied to VITE_DEV_API_PROXY_TARGET
# Staging: https://staging.api.varo.cloud/api
# Production: https://api.varo.cloud/api
VITE_API_BASE_URL=/api

# Vite public base path when deployed under a subdirectory.
# Production & staging (varo-staging.github.io): /
VITE_BASE=/

# -----------------------------------------------------------------------------
# Local development only (npm run dev)
# -----------------------------------------------------------------------------

# Origin to proxy /api requests to. Required when VITE_USE_MOCK=false and
# VITE_API_BASE_URL=/api. Example: https://staging.api.varo.cloud
VITE_DEV_API_PROXY_TARGET=

# Optional: skip login during local dev. Paste access_token from staging login;
# written to localStorage on dev server start. Expires in ~15 minutes.
VITE_DEV_AUTH_TOKEN=

# Optional: refresh_token paired with VITE_DEV_AUTH_TOKEN for automatic renewal.
VITE_DEV_REFRESH_TOKEN=

# Deprecated — use VITE_DEV_AUTH_TOKEN instead.
# VITE_DEV_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Third-party services
# -----------------------------------------------------------------------------

# Cloudflare Turnstile site key for login / register CAPTCHA.
# Dev test key (always passes): 1x00000000000000000000AA
# Staging build (CI) also uses the test key above; production uses a real key via GitHub Secret.
VITE_TURNSTILE_SITE_KEY=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
# Only sent in production builds.
VITE_GA_MEASUREMENT_ID=

# External API documentation site (Mintlify).
# Staging / local dev: https://varocloudtest.mintlify.site/docs
# Production: https://docs.varo.cloud
VITE_DOCS_URL=

# Inference API base URL shown in model detail API docs and playground code snippets.
# Staging / local dev: https://staging.inference.varo.cloud/v1
# Production: https://inference.varo.cloud/v1
VITE_INFERENCE_API_BASE_URL=
